{
  "name": "arduino-blocks",
  "version": "1.1.2",
  "description": "Programación por bloques para Arduino",
  "author": "Arduino Blocks",
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "start": "cross-env GENERATE_SOURCEMAP=false react-scripts start",
    "build": "cross-env GENERATE_SOURCEMAP=false react-scripts build",
    "electron": "electron .",
    "electron-dev": "concurrently \"cross-env BROWSER=none GENERATE_SOURCEMAP=false npm start\" \"wait-on http://localhost:3000 && electron .\"",
    "electron-build": "npm run build && electron-builder",
    "preelectron-build": "node scripts/download-arduino-cli.js",
    "download-cli": "node scripts/download-arduino-cli.js",
    "test": "react-scripts test"
  },
  "dependencies": {
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@monaco-editor/react": "^4.7.0",
    "@mui/icons-material": "^5.14.0",
    "@mui/material": "^5.14.0",
    "blockly": "^10.4.3",
    "electron-updater": "^6.8.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1"
  },
  "optionalDependencies": {
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.0",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "com.arduinoblocks.app",
    "productName": "Arduino Blocks",
    "extends": null,
    "files": [
      "build/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "artifactName": "Arduino-Blocks-Setup-${version}.${ext}",
      "extraResources": [
        {
          "from": "tools/win/",
          "to": "tools/",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "mac": {
      "target": "dmg",
      "extraResources": [
        {
          "from": "tools/mac/",
          "to": "tools/",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "linux": {
      "target": "AppImage",
      "extraResources": [
        {
          "from": "tools/linux/",
          "to": "tools/",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "EGgames",
      "repo": "arduino-blocks",
      "private": false
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ],
    "rules": {
      "no-unused-vars": "warn",
      "react-hooks/exhaustive-deps": "warn"
    }
  }
}
